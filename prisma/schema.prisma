generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// 👤 USERS
//
model User {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  role      UserRole @default(BUYER)
  email     String?  @unique   // ✅ optional (UI support)
  passwordHash String?          

  createdAt DateTime @default(now())

  isActive Boolean @default(true)

  // Relations
  properties  Property[]
  leads       Lead[]
  leadCredits LeadCredit[]
}

enum UserRole {
  OWNER
  AGENT
  BUYER
  ADMIN
}

//
// 🏡 PROPERTY LISTINGS
//
model Property {
  id          Int     @id @default(autoincrement())
  title       String
  description String?

  // 💰 Price (in INR)
  price Int?

  // 📍 Location
  address String
  city    String

  // 🔥 Tadoba USP
  gate TadobaGate

  // 📐 Area
  area     Float?
  areaUnit AreaUnit?

  type   PropertyType
  status PropertyStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 👤 Who created listing
  userId Int
  user   User @relation(fields: [userId], references: [id])

  // 👇 Owner (internal)
  ownerName  String?
  ownerPhone String?

  // 👇 Public contact
  contactName  String
  contactPhone String

  // 🖼️ Images
  images PropertyImage[]

  // ⭐ Controls
  isFeatured Boolean @default(false)

  // (optional future)
  slug String? @unique
  leads Lead[] @relation("PropertyLeads")

  // 🚀 Indexes
  @@index([city])
  @@index([gate])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

enum AreaUnit {
  ACRE
  SQFT
  GUNTHA
}

enum PropertyType {
  FARM
  PLOT
  AGRICULTURE
  RESIDENTIAL
  COMMERCIAL
}

enum PropertyStatus {
  DRAFT
  ACTIVE
  SOLD
  INACTIVE
}

//
// 🌿 TADOBA GATES (CORE FILTER)
//
enum TadobaGate {
  MOHARLI
  KOLARA
  NAVEGAON
  ZARI
  JUNONA
  DEVADA
  AGARZARI
  PANGDI
  KESLAGHAT
  ALIZANZA
  MADNAPUR
}

//
// 🖼️ PROPERTY IMAGES
//
model PropertyImage {
  id           Int      @id @default(autoincrement())
  propertyId   Int

  optimizedUrl String
  thumbnailUrl String

  createdAt    DateTime @default(now())

  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

//
// 📞 LEADS
//
model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  message   String?
  createdAt DateTime @default(now())

  // Property relation
  propertyId Int
  property   Property @relation("PropertyLeads", fields: [propertyId], references: [id])
  // Buyer (optional → guest allowed)
  buyerId Int?
  buyer   User? @relation(fields: [buyerId], references: [id])

  // Tracking
  isViewed Boolean @default(false)

  // 🚀 INDEXES
  @@index([propertyId])
  @@index([buyerId])
  @@index([createdAt])
}

//
// 💰 LEAD CREDITS (future monetization)
//
model LeadCredit {
  id        Int      @id @default(autoincrement())
  userId    Int
  credits   Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
